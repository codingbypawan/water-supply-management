# ─── Database ───
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=water_supply_db
DB_USER=root

# ─── JWT Secrets (generate with: openssl rand -base64 64) ───
JWT_SECRET=CHANGE_ME_random_jwt_secret
JWT_REFRESH_SECRET=CHANGE_ME_random_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS (comma-separated allowed origins) ───
CORS_ORIGINS=https://yourdomain.com,https://subdomain.yourdomain.com

# ─── VAPID Keys for Push Notifications (generate with: npx web-push generate-vapid-keys) ───
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
